{
  "moduleName": "Astropsychology",
  "version": "1.0.0",
  "order": 8,
  "description": "Модуль астропсихологии - психологический портрет по звездам",
  "dependencies": ["Core", "Logs"],

  "services": {
    "freeCalculations": 1,
    "paidCalculations": {
      "astro_basic": 0,
      "astro_standard": 300,
      "astro_full": 500,
      "astro_premium": 1000
    }
  },

  "serviceTypes": {
    "astro_basic": {
      "name": "Базовый анализ",
      "description": "Основной психологический портрет по Солнцу, Луне и Асценденту",
      "features": [
        "Асцендент (восходящий знак)",
        "Солнце (сущность, эго)",
        "Луна (эмоции, подсознание)",
        "Базовый психологический портрет",
        "Ключевые сильные стороны"
      ],
      "price": 0,
      "free": true
    },
    "astro_standard": {
      "name": "Стандартный портрет",
      "description": "Полный психологический портрет личности",
      "features": [
        "Всё из базового анализа",
        "Все 10 планет в знаках",
        "Психологический анализ характера",
        "Сильные стороны и зоны роста",
        "Путь развития",
        "Прогноз на месяц"
      ],
      "price": 300
    },
    "astro_full": {
      "name": "Глубокий анализ",
      "description": "Глубокий анализ личности, аспекты, дома, годовой прогноз",
      "features": [
        "Всё из стандартного портрета",
        "Анализ аспектов между планетами",
        "Психологический портрет по домам",
        "Анализ отношений (совместимость)",
        "Годовой прогноз",
        "Натальная карта (визуализация)",
        "Скачивание PDF-отчета"
      ],
      "price": 500
    },
    "astro_premium": {
      "name": "Премиум-портрет",
      "description": "Максимально полный разбор личности + транзитный прогноз + кармический анализ",
      "features": [
        "Всё из глубокого анализа",
        "Детальный разбор всех аспектов",
        "Проработка кармических задач",
        "Транзитный прогноз на 3 месяца",
        "Персональные рекомендации",
        "Аффирмация дня",
        "Приоритетная поддержка"
      ],
      "price": 1000
    }
  },

  "overview": {
    "summary": "Модуль предоставляет психологический портрет личности на основе астрологических данных.",
    "features": [
      "Бесплатный базовый анализ",
      "Платные расширенные расчеты",
      "Сохранение истории расчетов",
      "Генерация PDF отчетов",
      "Интеграция с балансом пользователя",
      "4 уровня глубины анализа"
    ]
  },

  "endpoints": {
    "public": [
      {
        "method": "GET",
        "path": "/api/astropsychology/types",
        "description": "Получить список типов расчетов",
        "auth": false
      }
    ],
    "protected": [
      {
        "method": "POST",
        "path": "/api/astropsychology/calculate/:type",
        "description": "Расчет астропсихологического портрета",
        "auth": true,
        "price": "по типу"
      },
      {
        "method": "GET",
        "path": "/api/astropsychology/history",
        "description": "История расчетов",
        "auth": true
      },
      {
        "method": "GET",
        "path": "/api/astropsychology/calculations/:id",
        "description": "Получение конкретного расчета",
        "auth": true
      },
      {
        "method": "GET",
        "path": "/api/astropsychology/pdf/:id",
        "description": "Скачать PDF отчета",
        "auth": true
      }
    ]
  },

  "webInterface": {
    "url": "/astropsychology",
    "features": [
      "Выбор типа расчета",
      "Форма ввода данных",
      "Визуализация натальной карты",
      "Личный кабинет с историей"
    ]
  },

  "author": "System",
  "license": "Proprietary"
}